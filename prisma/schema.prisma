generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Story {
  id        String   @id @default(cuid())
  title     String
  content   String
  lesson    String
  topic     String
  age       String
  createdAt DateTime @default(now())
}
